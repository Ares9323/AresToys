<ui:FluentWindow x:Class="ShareQ.App.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ShareQ - Launcher"
        Icon="pack://application:,,,/Assets/icon.ico"
        Width="1280" Height="640"
        MinWidth="800" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="None"
        Background="{DynamicResource Surface2Brush}"
        ExtendsContentIntoTitleBar="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        KeyDown="OnKeyDown"
        Deactivated="OnDeactivated"
        Closing="OnLauncherClosing">
    <ui:FluentWindow.Resources>
        <!-- Per-cell right-click menu. Single shared instance — DataContext is rebound to the
             clicked cell's view-model via the PlacementTarget binding so each invocation
             carries the right cell's payload. The five entries match the conventional file-
             manager actions on a slot: jump to its source on disk, edit, copy/paste between
             slots (own clipboard, doesn't touch the OS clipboard), wipe. -->
        <ContextMenu x:Key="LauncherCellMenu"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="Open file location" Click="OnMenuOpenLocation" />
            <MenuItem Header="Edit…"              Click="OnMenuEdit" />
            <Separator />
            <MenuItem Header="Copy"               Click="OnMenuCopy" />
            <MenuItem Header="Paste"              Click="OnMenuPaste" />
            <Separator />
            <MenuItem Header="Delete"             Click="OnMenuDelete" />
        </ContextMenu>
    </ui:FluentWindow.Resources>
    <!-- Accent-tinted 2px frame around the whole window content (titlebar + body), matching
         MainWindow / ImageEffectsWindow / GradientEditorWindow / QrGeneratorWindow. FluentWindow's
         own chrome stays outside this Border, so the accent line reads as an inner "telaio". -->
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource AccentForegroundDarkBrush}" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0 titlebar -->
                <RowDefinition Height="*" />     <!-- 1 main content -->
            </Grid.RowDefinitions>

            <!-- WPF-UI titlebar — handles drag, double-click maximise, min/max/close buttons,
                 dark caption color via DWM. Replaces the old custom drag-on-mode chrome that had
                 to live inside an AllowsTransparency=True window. Standard edge-resize comes
                 with FluentWindow so the conditional Thumb resize is gone. -->
            <ui:TitleBar Grid.Row="0" Title="ShareQ - Launcher">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="{StaticResource ShareQLogo}" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>

        <Grid Grid.Row="1" Margin="14,0,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 0: header (mode banner + toggle + search) -->
                <RowDefinition Height="Auto" />  <!-- 1: F-strip -->
                <RowDefinition Height="Auto" />  <!-- 2: gap -->
                <RowDefinition Height="Auto" />  <!-- 3: tab strip -->
                <RowDefinition Height="*" />     <!-- 4: row 1 — split the leftover height equally -->
                <RowDefinition Height="*" />     <!-- 5: row 2 -->
                <RowDefinition Height="*" />     <!-- 6: row 3 -->
                <RowDefinition Height="Auto" />  <!-- 7: footer -->
            </Grid.RowDefinitions>

            <!-- ── Header: drag-mode banner + drag toggle + search. Title + icon now live in
                  the ui:TitleBar above; this row only carries the controls that act on the
                  launcher state. ─────────────────────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DragModeBanner" Grid.Column="0"
                           Text="🎯 Drag-and-drop mode — drop files / folders / shortcuts onto cells to map them. Esc or click toggle to exit."
                           Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="11" VerticalAlignment="Center"
                           Visibility="Collapsed" />
                <!-- Drag toggle sits left of the search box now: search lives at the extreme
                     right (consistent placement with the popup's search) and the toggle
                     button is the secondary action that bumps inward. -->
                <ui:Button Grid.Column="1" x:Name="DragToggle" Content="📥 Drag mode"
                           Padding="10,4" FontSize="11" Margin="0,0,8,0" Click="OnDragToggleClick"
                           ToolTip="Toggle drag-and-drop mode — the launcher stays open and cells accept dropped files / folders / shortcuts." />
                <ui:TextBox Grid.Column="2" x:Name="SearchBox"
                            PlaceholderText="🔍 Search…"
                            FontSize="11"
                            TextChanged="OnSearchTextChanged"
                            ToolTip="Filter cells by label or path. Empty cells and the F-row are unaffected; tabs without matches lose their title." />
            </Grid>

            <!-- ── Function-key strip — global, visible regardless of selected tab ──────────── -->
            <ItemsControl x:Name="FunctionRow" Grid.Row="1">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                Height="84"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- F-row: same layout shape as the QWERTY rows below — corner
                                     badge + centred icon (same 40px size) + label underneath.
                                     Function-key glyphs (F1, F2…) get Bold to read more like
                                     keycap labels and stand out from the QWERTY corner badges. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="2" Height="8" /> <!-- gap between the function keys and the tab strip -->

            <ItemsControl x:Name="TabStrip" Grid.Row="3">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3,0" CornerRadius="6,6,0,0"
                                Background="{Binding HeaderBackground}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1,1,1,0"
                                MouseLeftButtonDown="OnTabClick"
                                MouseRightButtonDown="OnTabRightClick"
                                Cursor="Hand"
                                Tag="{Binding TabKey}"
                                Height="44"
                                Visibility="{Binding HeaderVisibility}"
                                ToolTip="Right-click to rename this tab — drop a file to switch tab without firing.">
                            <Grid Margin="6,4">
                                <TextBlock Text="{Binding TabKey}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" />
                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Accent panel painted behind the active tab's QWERTY grid. The Border spans the
                 three key rows so the tab and its content read as one continuous coloured zone
                 (same convention as a TabControl's selected page). Z-order: declared first so
                 the cells render on top. All four corners round so the panel reads as a real
                 self-contained card regardless of which tab is active (the active tab might be
                 anywhere in the strip, not necessarily the first slot). -->
            <Border Grid.Row="4" Grid.RowSpan="3"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    CornerRadius="6"
                    Margin="-3,0,-3,-3" />

            <ItemsControl x:Name="Row1Host" Grid.Row="4" Margin="0,4,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="Row2Host" Grid.Row="5" Margin="0,0,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="Row3Host" Grid.Row="6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="3" CornerRadius="6"
                                Background="{DynamicResource AccentBackgroundDarkBrush}"
                                BorderBrush="{DynamicResource AccentBackgroundDarkBorderBrush}" BorderThickness="1"
                                MouseLeftButtonDown="OnCellClick"
                                PreviewMouseLeftButtonDown="OnCellPreviewMouseDown"
                                PreviewMouseMove="OnCellPreviewMouseMove"
                                ContextMenu="{StaticResource LauncherCellMenu}"
                                Cursor="Hand"
                                Tag="{Binding ComposedKey}"
                                ToolTip="{Binding Path}"
                                ToolTipService.IsEnabled="{Binding HasPath}"
                                Visibility="{Binding CellVisibility}"
                                AllowDrop="True"
                                DragEnter="OnCellDragEnter"
                                DragLeave="OnCellDragLeave"
                                Drop="OnCellDrop">
                            <Grid Margin="6">
                                <!-- KeyChar floats top-left as a corner badge; icon + label stack
                                     vertically and the whole stack is centred in the cell. The
                                     StackPanel sizes to content + child stretch, so a label that
                                     overflows on one line wraps onto a second/third without the
                                     icon shifting. Cells stay a fixed Height (set on the Border
                                     above), so longer labels just push the icon up slightly. -->
                                <TextBlock Text="{Binding DisplayKeyChar}" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Panel.ZIndex="1" />
                                <StackPanel VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AccentForegroundBrush}"
                                               FontSize="11" TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="7" Margin="0,10,0,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AccentForegroundDarkBrush}" FontSize="10"
                       Text="F1-F10 fire global · 1-9,0 / arrows switch tab · QWERTY fires tab cell · Esc closes · right-click to edit" />

        </Grid>
    </Grid>
    </Border>
</ui:FluentWindow>
